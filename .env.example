# ──────────────────────────────────────────────────────────────
# HOTWORX Lookbook — Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: add these under Project → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────

# The base URL of the Shopify apparel store (no trailing slash)
SHOPIFY_STORE_URL=https://hotworxapparel.com

# The storefront password for the password-protected Shopify store
SHOPIFY_PASSWORD=HWXPW1

# Price markup multiplier applied to all Shopify prices before displaying
# 2.0 = double the wholesale price (default)
# Change this any time without touching code — just update this value and redeploy.
PRICE_MARKUP=2.0

# Formspree form ID — sign up free at https://formspree.io
# Create a form, copy the ID from the endpoint (e.g. "xaabbccdd" from https://formspree.io/f/xaabbccdd)
# Leave blank to skip email notifications (orders will still show in Vercel function logs)
FORMSPREE_ID=
